# Allure TestOps Configuration
# Copy this file to .env and fill in your actual values

# Base URL of your Allure TestOps instance
# Example: https://allure.example.com or https://allure.cloud
ALLURE_BASE_URL=https://your-allure-domain.com

# Allure API Token
# Get this from your Allure TestOps instance:
# Settings > API Tokens > Create New Token
ALLURE_TOKEN=your_allure_api_token_here

# HTTP Request Timeout (in seconds)
# Default: 30
REQUEST_TIMEOUT=30
