# Example Caddyfile for Allure MCP Server with automatic HTTPS
# Install Caddy: https://caddyserver.com/docs/install

# Development (auto-HTTPS via local CA)
allure-mcp.local {
    reverse_proxy localhost:3000 {
        header_up Upgrade websocket
        header_up Connection upgrade
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
    }

    # Rate limiting (10 requests per second, burst of 20)
    rate_limit 10r/s burst=20

    # Disable automatic redirects for SSE connections
    log {
        output stdout
        level debug
    }
}

